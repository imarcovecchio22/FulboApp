DATABASE_URL="postgresql://postgres:password@localhost:5432/appfulbo"
PORT=3001
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# ATC Sports / AlquilaTuCancha integration
# The real API endpoint discovered: GET /api/v3/place/search?lat=LAT&lng=LNG&sport_id=1&date=DATE
# Auth is required — obtain a Bearer token by logging into atcsports.io and copying it from DevTools > Network > Authorization header
ATC_BASE_URL="https://atcsports.io"
ATC_API_KEY=""          # Bearer JWT token from atcsports.io login session
ATC_EMAIL=""            # Optional: email to use with Playwright scraper
ATC_PASSWORD=""         # Optional: not used (ATC uses magic links) — reserved for future

# Location for ATC venue search (default: Buenos Aires city center)
ATC_SEARCH_LAT="-34.6037"
ATC_SEARCH_LNG="-58.3816"
ATC_SPORT_ID="1"        # 1=fútbol, 2=pádel, 3=tenis

# Cache TTL in seconds (default: 5 minutes)
CACHE_TTL_SECONDS=300
